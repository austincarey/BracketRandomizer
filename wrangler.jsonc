{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bracket-randomizer",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "bracketrandomizer.com", "custom_domain": true },
    { "pattern": "www.bracketrandomizer.com", "custom_domain": true }
  ]
}
